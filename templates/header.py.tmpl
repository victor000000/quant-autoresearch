    # if it survives, the "edge" is an artifact (drift/sizing/leak), not label signal.
    # Default "0" => off => byte-identical legacy renders. Writes a DISTINCT _perm cell.
    "permute_labels": _cfg_or("__PERMUTE__", "__" "PERMUTE__", "0") == "1",
    # Reducer width (correlation reduce_dims n_components). Default 20 (Wang backbone).
    # An override (e.g. 30/15) is the program-sanctioned "reduce" lever — writes a DISTINCT _n cell.
    "n_components": int(_cfg_or("__NCOMP__", "__" "NCOMP__", "20")),
    # Rebalance ADJUSTMENT dead-band: skip a re-trade when the target weight moves < band. Default
    # 0.01 (byte-identical). Wider (e.g. 0.05 for high-frequency GLD) cuts trades -> less cost drag
    # (the validated net-of-cost deployment lever). Saved in the cell payload; infer reads + applies it.
    "rebal_band": float(_cfg_or("__REBALBAND__", "__" "REBALBAND__", "0.01")),
    # Forward-label horizons override (in BARS) — the INTRADAY-holding search dimension. None =>
    # labelers use their built-in (~daily) horizons; a short list => intraday regime. Distinct _hz cell.
    "horizons": _HZ,
    # Dimensionality-reduction method (Wang ④). Default "correlation" (byte-identical legacy). "infogain"
    # = Wang's INFORMATION-GAIN selection: top-K features by mutual-info with the TRAIN label (label-
    # relevant, not variance) — fixes the corr-filter's label-agnostic crowding. Distinct _ig cell.
    "reduce": _cfg_or("__REDUCE__", "__" "REDUCE__", "correlation"),
    # Feature set. Default "base" (the 80-feature panel, byte-identical legacy). "rich" APPENDS
    # variance-ratio trend-persistence features that HURT under the corr-filter (crowding) but which
    # the label-relevant IG reducer can select without crowding. Pair with reduce=infogain. Distinct _fr cell.
    "features": _cfg_or("__FEATURES__", "__" "FEATURES__", "base"),
}
# Cell-key suffix for the permuted-label control (distinct cell -> never overwrites a champion).
# Precomputed as a plain name so f-string keys stay simple (no nested conditional/quotes, which
# QC's Python rejects after ast.unparse re-emits the f-string).
_PSUF = ("_perm" if CONFIG["permute_labels"] else "") + ("" if CONFIG["n_components"] == 20 else "_n" + str(CONFIG["n_components"])) + ("" if CONFIG["rebal_band"] == 0.01 else "_b" + str(int(round(CONFIG["rebal_band"] * 100)))) + ("" if CONFIG["horizons"] is None else "_hz" + "x".join(str(_h) for _h in CONFIG["horizons"])) + ("" if CONFIG["reduce"] == "correlation" else "_ig" if CONFIG["reduce"] == "infogain" else "_rd" + str(CONFIG["reduce"])) + ("" if CONFIG["features"] == "base" else "_fr" if CONFIG["features"] == "rich" else "_ts" if CONFIG["features"] == "termstruct" else "_fx")
