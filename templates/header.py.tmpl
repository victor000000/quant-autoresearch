# Axis this train run sweeps. The orchestrator substitutes __AXIS__ with one axis
# name (e.g. "vol", "dollar", "tick") for a per-axis train backtest. If left as
# the literal "__AXIS__" (not substituted), the footer sweeps ALL axes.
AXIS = "__AXIS__"

# A hypothesis is FULLY render-time config: the orchestrator substitutes the five
# placeholders below (NO code edits between hypotheses). The footer then builds
# ONLY CONFIG['axis'] and runs ONLY CONFIG['labeler'] as ONE cell, sizing with
# CONFIG['sizing'] + CONFIG['thresh'] (same rule reused in infer OOS).
#   axis    in bar_builder.AXES (dollar,tick,vol,range,logdollar,entropy)
#   labeler in labeler.LABELERS (kmeans2stage,carry,tertile,bgm,agglomerative,
#                                triple_barrier,multi_horizon,hmm,always_long)
#   thresh  per-ETF entry threshold (e.g. 0.10-0.55)
#   sizing  in {ramp, binary, cdf_plain, cdf_overlay}
# BACK-COMPAT: if __AXIS__/__LABELER__ are left literal (not substituted), the
# footer ignores CONFIG and falls back to the existing full sweep, so the old
# per-axis drivers (render_script(ticker, axis)) keep working unchanged.
def _cfg_or(val, placeholder, fallback):
    return fallback if val == placeholder else val


# INTRADAY-holding search lever (2026-06-03): optional forward-label horizons override (in BARS).
# Default null -> labelers use their built-in horizons (~daily holding). Short horizons (e.g.
# [5, 10, 20] bars) target an INTRADAY-horizon edge regime (a different holding regime, untested).
# Bulletproof parse: any malformed / non-positive-int value falls back to None (= legacy defaults).
_HZRAW = _cfg_or("__HORIZONS__", "__" "HORIZONS__", "null")
try:
    _HZ = json.loads(_HZRAW)
    if not (isinstance(_HZ, list) and len(_HZ) > 0 and all(isinstance(_h, int) and _h > 0 for _h in _HZ)):
        _HZ = None
except Exception:
    _HZ = None


CONFIG = {
    "ticker": TICKER,
    "axis": _cfg_or("__AXIS__", "__" "AXIS__", None),
    "labeler": _cfg_or("__LABELER__", "__" "LABELER__", None),
    "thresh": float(_cfg_or("__THRESH__", "__" "THRESH__", "nan")),
    "sizing": _cfg_or("__SIZING__", "__" "SIZING__", "cdf_overlay"),
    # Model capacity (XGBoost tree depth). Defaults to 3 (shallow, regularized) so
    # every legacy render is byte-identical; an explicit override enables capacity A/B.
    "max_depth": int(_cfg_or("__MAXDEPTH__", "__" "MAXDEPTH__", "3")),
    # Permuted-label FALSIFICATION CONTROL (research 2026-06-03): shuffle the TRAIN
