"""Footer — SCIENTIFIC axis x labeling sweep, run in on_end_of_algorithm.

For the axis(es) named by AXIS (header) and EACH labeler in the LABELERS registry
we run a FIXED downstream pipeline and save that (axis,label) cell's TEST-period
predictions to ObjectStore. REAL Calmar comes from a separate infer backtest
(templates/infer.py.tmpl) that replays these predictions with real SetHoldings.

FIXED downstream (identical for every cell — do NOT vary):
    build_feats  ->  StandardScaler  ->  reduce_dims(correlation, 20)
    ->  XGBoost(max_depth=3, learning_rate=0.03, n_estimators=200,
                scale_pos_weight=class_balance)
    ->  isotonic calibration (fit on VAL)
    ->  realistic_cstats on VAL  (synthetic selection metric)

reduce_dims / realistic_cstats are reused from trainer.py (globals at runtime).

THRESHOLD CONSISTENCY: a single per-ETF threshold is chosen per cell, used for
synthetic selection AND saved in the cell payload, so infer applies the SAME
threshold (fixes the historical train/infer threshold mismatch).

Cell payload key:   autoresearch/{TICKER}/cell_{axis}_{label}.json
  -> {ticker, axis, label, cfg, thresh, predictions}
Manifest key:       autoresearch/{TICKER}/manifest.json
  -> {ticker, cells: [{key, axis, label, synth_cal, train_auc, val_auc, n_trades}], ...}
"""


def _cell_threshold(ticker):
    """Per-ETF entry threshold (consistent across synth selection AND infer)."""
    if ticker in ["XLE"]:
        return 0.10
    if ticker == "QQQ":
        return 0.15
    if ticker in ["HYG", "TLT"]:
        return 0.55
    if ticker == "GLD":
        return 0.35
    return 0.45


# Render-time sizing for ONE hypothesis. The SAME _size() rule runs here (VAL,
# inside _cstats_sized) and in the infer template (OOS), keyed by CONFIG['sizing'].
# rbuf = trailing bar log-returns KNOWN at this bar (causal; only the overlay uses it).
_VOL_FAST = 10
_VOL_SLOW = 60


def _size(p, thresh, sizing, rbuf):
    """Return target weight in [0,1] for prob p under the named sizing mode.
      ramp        = min(1,(p-thresh)*200) if p>thresh else 0          (legacy)
      binary      = 1.0 if p>thresh else 0.0                          (label-responsive)
      cdf_plain   = clip(2*Phi((p-thresh)/sqrt(p(1-p)))-1,0,1) if p>thresh else 0
      cdf_overlay = cdf_plain * clip(std_slow/std_fast, 0.6, 1.0)     (vol-targeted)
      longshort   = +1 if p>thresh, -1 if p<1-thresh, else 0          (SHORT-capable)
      ls_cdf      = clip(2*Phi((p-.5)/sqrt(p(1-p)))-1, -1, 1)         (continuous long/short)
    """
    if sizing == "crashveto":          # tail-risk veto: full long unless a crash is predicted (p_crash > thresh) -> flat
        return 0.0 if p > thresh else 1.0
    if sizing == "longshort":
        return 1.0 if p > thresh else (-1.0 if p < 1.0 - thresh else 0.0)
    if sizing in ("ls_cdf", "ls_overlay"):
        pp = min(max(p, 1e-6), 1.0 - 1e-6)
        zc = (pp - 0.5) / math.sqrt(pp * (1.0 - pp))
        w = float(min(1.0, max(-1.0, 2.0 * 0.5 * (1.0 + math.erf(zc / math.sqrt(2.0))) - 1.0)))
        if sizing == "ls_overlay":              # vol-target the long/short magnitude, keep sign (causal)
            m = len(rbuf)
            if m >= _VOL_FAST + 2:
                fast = float(np.std(rbuf[-_VOL_FAST:]))
                slow = float(np.std(rbuf[-min(m, _VOL_SLOW):]))
                if fast > 1e-9:
                    w *= float(min(1.0, max(0.45, slow / fast)))
        return w
    if sizing == "binary":
        return 1.0 if p > thresh else 0.0
    if sizing == "ramp":
        return float(min(1.0, (p - thresh) * 200.0)) if p > thresh else 0.0
    if p <= thresh:
        return 0.0
    pp = min(max(p, 1e-6), 1.0 - 1e-6)
    z = (pp - thresh) / math.sqrt(pp * (1.0 - pp))
    b = 2.0 * 0.5 * (1.0 + math.erf(z / math.sqrt(2.0))) - 1.0  # 2*Phi(z)-1
    b = float(min(1.0, max(0.0, b)))
    if sizing == "cdf_overlay":
        m = len(rbuf)
        if m >= _VOL_FAST + 2:
            fast = float(np.std(rbuf[-_VOL_FAST:]))
            slow = float(np.std(rbuf[-min(m, _VOL_SLOW):]))
            if fast > 1e-9:
                b *= float(min(1.0, max(0.6, slow / fast)))
    if sizing == "dd_overlay":          # drawdown-aware: throttle the bet when the asset is
        m = len(rbuf)                   # underwater vs its recent rolling peak (causal, rbuf only)
        if m >= _VOL_FAST + 2:
            win = np.asarray(rbuf[-min(m, _VOL_SLOW):], dtype=float)
            cum = np.cumsum(win)                       # recent log-equity of the asset
            dd = float(cum[-1] - float(np.max(cum)))   # <= 0: current log DD from recent peak
            ref = 3.0 * float(np.std(win)) * math.sqrt(len(win))   # vol-normalized DD scale (~3σ)
            if ref > 1e-9:
                b *= float(min(1.0, max(0.5, 1.0 + dd / ref)))     # 1.0 at peak -> 0.5 floor when deep
    return b


def _cstats_sized(probs, lc_arr, log_rets, thresh, sizing, tc=0.0005):
    """realistic_cstats variant that sizes via _size() (CONFIG['sizing']).
    Mirrors trainer.realistic_cstats accounting (decide-then-append causal rbuf,
    0.01 rebalance dead-band, tc on |delta|). Returns (calmar,trades,tot,mdd,ann,da)."""
    n = min(len(probs) - 1, len(log_rets) - 1, len(lc_arr) - 1)
    if n < 2:
        return 0, 0, 0, 0, 0, 0.0
    positions = np.zeros(n + 1)
    last_pos = 0.0
    trades = 0
    rbuf = []
    for i in range(n):
        target = _size(float(probs[i]), thresh, sizing, rbuf)
        # Abs-delta dead-band — mirrors infer.py's rebalance band so val turnover/cost
        # matches OOS for long/short sizings too (the old long-only-flavoured condition
        # under-counted short flips).
        if abs(target - last_pos) > CONFIG["rebal_band"]:
            trades += 1
        positions[i] = target
        last_pos = target
        if i - 1 >= 0:
            rbuf.append(float(log_rets[i - 1]))
    if trades < 2:
        return 0, trades, 0, 0, 0, 0.0
    strat_rets = positions[:-1] * log_rets[1:n + 1]
    for i in range(1, n):
        if abs(positions[i] - positions[i - 1]) > CONFIG["rebal_band"]:
            strat_rets[i] -= tc * abs(positions[i] - positions[i - 1])
    cum = np.cumsum(strat_rets)                       # cumulative log-return == log-equity
    peak = np.maximum.accumulate(cum)
    dd = cum - peak                                   # log drawdown (<= 0)
    # COMPOUNDED metric, to match the REAL OOS estimator (QC 'Compounding Annual
    # Return' / 'Drawdown'): val must use the SAME definition as the keep gate, else
    # the synth selector reads systematically higher than OOS and is not a faithful
    # preview. (The residual val<->OOS gap after this is honest realism: OOS holds
    # continuously across minutes + overnight with real fees.)
    mdd = 1.0 - float(np.exp(float(np.min(dd))))      # max drawdown as a fraction
    if mdd < 1e-9:
        mdd = 1e-9
    cagr = float(np.exp(float(cum[-1]) * (880.0 / n))) - 1.0   # compounded annual return
    da = float(np.sum(1.0 - np.exp(dd)))              # compounded underwater area
    cal = cagr / mdd if mdd > 0.001 else 0
    return cal, trades, float(np.sum(strat_rets)), mdd, cagr, da


class AutoresearchPipeline(QCAlgorithm):
    def initialize(self):
        self.set_start_date(2009, 8, 1)
        self.set_end_date(2026, 6, 1)
        self.set_cash(100000)
        self.sym = self.add_equity(TICKER, Resolution.MINUTE).symbol
        self.spy = self.add_equity(CROSS_ASSET, Resolution.MINUTE).symbol
        self.tsl = []
        self.cll = []
        self.vll = []
        self.spy_cll = []  # SPY close prices for cross-asset features

    def on_data(self, slice):
        if self.sym not in slice.bars:
            return
        b = slice.bars[self.sym]
        self.tsl.append(b.end_time)
        self.cll.append(float(b.close))
        self.vll.append(float(b.volume))
        if self.spy in slice.bars:
            self.spy_cll.append(float(slice.bars[self.spy].close))
        else:
            self.spy_cll.append(self.spy_cll[-1] if self.spy_cll else 0.0)

    # --------------------------------------------------------------------- #
    # FIXED downstream pipeline for one (axis, labeler) cell.               #
    # Returns (synth_cal, cfg, train_auc, val_auc, n_trades, test_preds)    #
    # or None when the cell cannot be trained.                             #
    # --------------------------------------------------------------------- #
    def _run_cell(self, feats, y, label_cfg, tr_m, va_m, te_m, lc, lr, bar_ts, fv,
                  thresh, sizing="cdf_overlay", meta=False, ae=False):
        try:
            from sklearn.preprocessing import StandardScaler
            from sklearn.metrics import roc_auc_score
            import xgboost as xgb
        except ImportError:
            return None

        # ---- NO-LOOKAHEAD INVARIANT (G3) ----------------------------------- #
        # The label y is future-derived. It MAY filter the bars used to FIT the
        # model/calibrator (training on future labels is allowed). It must NEVER
        # decide WHICH out-of-sample bars get a position — doing so picks trades
        # with hindsight. So: fit on labeled bars; but emit VAL-synth + TEST
        # predictions for EVERY causal bar (fv & mask), no future-label filter.
        ly = y >= 0
        # EMBARGO (purge): labels use up to ~200 forward bars, so val bars within
        # H of the val/test boundary carry EARLY-TEST returns. They must not enter
        # the calibrator/model fit (would bleed test info). Drop them from the FIT
        # sets only; the model is train-fit and TRAIN labels can't reach test (val
        # is years wide >> H), so only the val->test boundary needs the embargo.
        _EMBARGO = 200
        _allidx = np.arange(len(y))
        _tepos = np.where(te_m)[0]
        emb = (_allidx < (_tepos[0] - _EMBARGO)) if len(_tepos) else np.ones(len(y), dtype=bool)
        tx = fv & ly & tr_m                 # train: labeled bars only (model fit)
        y_fit = y                           # permuted-label control: shuffle ONLY the TRAIN
        if CONFIG.get("permute_labels"):    # labels the model fits on (test still enters via
            y_fit = y.copy()                # predict only -> leak-safe). Preserves class balance,
            _tri = np.where(tx)[0]          # so scale_pos_weight/n_pos/n_neg are unchanged.
            y_fit[_tri] = np.random.RandomState(1234).permutation(y[_tri])
        vx_lab = fv & ly & va_m & emb       # val labeled, EMBARGOED: calibrator fit + val_auc
        vx = fv & va_m                      # val ALL causal bars: synth metric
        ex = fv & te_m                      # test ALL causal bars: OOS preds (no label filter)
        if tx.sum() < 200 or vx_lab.sum() < 30 or ex.sum() < 30:
            return None

        # FIXED: StandardScaler -> correlation reduce_dims(20). (fit on TRAIN only)
        sc = StandardScaler()
        Xt_raw = sc.fit_transform(feats[tx])
        Xv_raw = sc.transform(feats[vx])
        Xe_raw = sc.transform(feats[ex])
        Xt, Xv, Xe, nk, dim_name, kept_idx = reduce_dims(
            Xt_raw, Xv_raw, Xe_raw, method=("autoencoder" if ae else "correlation"),
            n_components=int(CONFIG.get("n_components", 20)))

        vi = np.where(vx)[0]
        ei = np.where(ex)[0]
        vlab = ly[vi] & emb[vi]             # labeled, EMBARGOED subset within the ALL-val bars (aligns with vx_lab)
        n_pos = int(y[tx].sum())
        n_neg = int((1 - y[tx]).sum())

        if n_pos == 0 or n_neg == 0:
            # Single-class baseline (e.g. always_long): bypass the model with a
            # constant long signal == buy-and-hold. No fit, no AUC.
            pv_cal = np.ones(len(vi))
            pe_cal = np.ones(len(ei))
            train_auc = val_auc = 0.5
        else:
            # XGBoost lr0.03 / n200 / scale_pos_weight. depth defaults to 3 (shallow,
            # regularized); CONFIG['max_depth'] can override for capacity A/B (leak-safe
            # hyperparameter — train/val/embargo logic unchanged).
            # XGBoost lr0.03 / n200 / scale_pos_weight. depth defaults to 3 (shallow,
            # regularized); CONFIG['max_depth'] can override for capacity A/B (leak-safe
            # hyperparameter — train/val/embargo logic unchanged).
            # NOTE: a CONFIG['model']='extratrees' branch was tried (2026-06-03) — sklearn
            # ExtraTrees ERRORS in QC's on_end_of_algorithm runtime (platform-blocked, even
            # bounded to 200 trees/depth12). XGBoost is the QC-supported learner. Reverted.
            scale_w = n_neg / max(1, n_pos)
            _md = int(CONFIG.get("max_depth", 3))
            try:
                m = xgb.XGBClassifier(
                    n_estimators=200, max_depth=_md, learning_rate=0.03,
                    reg_alpha=1.0, reg_lambda=2.0, subsample=0.85, colsample_bytree=0.85,
                    scale_pos_weight=scale_w, objective="binary:logistic",
                    eval_metric="auc", tree_method="hist", random_state=42, n_jobs=1,
                    early_stopping_rounds=30, base_score=0.5)
                m.fit(Xt, y_fit[tx], eval_set=[(Xv[vlab], y[vx_lab])], verbose=False)
            except Exception:
                return None
            pt_raw = m.predict_proba(Xt)[:, 1]
            pv_raw = m.predict_proba(Xv)[:, 1]        # ALL val bars
            pe_raw = m.predict_proba(Xe)[:, 1]        # ALL test bars
            try:
                train_auc = float(roc_auc_score(y[tx], pt_raw))
                val_auc = float(roc_auc_score(y[vx_lab], pv_raw[vlab]))  # labeled val only
            except ValueError:
                train_auc = 0.5
                val_auc = 0.5
            # FIXED: isotonic calibration, fit on labeled VAL; applied to ALL bars.
            try:
                from sklearn.isotonic import IsotonicRegression
                cal = IsotonicRegression(out_of_bounds='clip', y_min=0.0, y_max=1.0)
                cal.fit(np.clip(pv_raw[vlab], 1e-6, 1 - 1e-6), y[vx_lab])
                pv_cal = cal.transform(np.clip(pv_raw, 1e-6, 1 - 1e-6))
                pe_cal = cal.transform(np.clip(pe_raw, 1e-6, 1 - 1e-6))
            except Exception:
                pv_cal, pe_cal = pv_raw, pe_raw

        _meta_booster_json = None      # set when the meta secondary is built -> carried in the online bundle
        _meta_gate = None
        # META-LABELING (Wang's "trading-decision secondary model" / AFML Ch.3): a
        # SECONDARY model predicts whether the PRIMARY's directional call is correct,
        # and shrinks the primary signal toward neutral where the secondary distrusts
        # it -> higher precision, fewer false trades. Honest meta-labels need OOS
        # primary preds, so the primary is re-fit over 3 contiguous PURGED folds of
        # TRAIN to score each train bar out-of-sample. Any failure -> primary-only (no-op).
        if meta and n_pos > 0 and n_neg > 0:
            try:
                ytx = y[tx]
                idx_tx = np.where(tx)[0]                  # full-N positions (time-sorted)
                ntr = len(idx_tx)
                oos_pt = np.full(ntr, np.nan)
                K = 3
                bnd = [int(ntr * f / K) for f in range(K + 1)]
                for kf in range(K):
                    a, b = bnd[kf], bnd[kf + 1]
                    if b - a < 20:
                        continue
                    keep = np.ones(ntr, dtype=bool)
                    keep[a:b] = False                    # hold out this contiguous fold
                    purge = (idx_tx >= idx_tx[a] - _EMBARGO) & (idx_tx <= idx_tx[b - 1] + _EMBARGO)
                    keep = keep & ~purge                 # purge label-overlapping bars near the fold
                    if keep.sum() < 100 or len(np.unique(ytx[keep])) < 2:
                        continue
                    swk = float(np.sum(ytx[keep] == 0)) / max(1, int(np.sum(ytx[keep] == 1)))
                    mk = xgb.XGBClassifier(
                        n_estimators=200, max_depth=3, learning_rate=0.03,
                        reg_alpha=1.0, reg_lambda=2.0, subsample=0.85, colsample_bytree=0.85,
                        scale_pos_weight=swk, objective="binary:logistic",
                        eval_metric="auc", tree_method="hist", random_state=42, n_jobs=1,
                        base_score=0.5)
                    mk.fit(Xt[keep], ytx[keep])
                    oos_pt[a:b] = mk.predict_proba(Xt[a:b])[:, 1]
                ok = ~np.isnan(oos_pt)
                meta_y = ((oos_pt[ok] >= 0.5).astype(int) == ytx[ok]).astype(int)
                if int(ok.sum()) > 200 and len(np.unique(meta_y)) == 2:
                    swm = float(np.sum(meta_y == 0)) / max(1, int(np.sum(meta_y == 1)))
                    ms = xgb.XGBClassifier(
                        n_estimators=200, max_depth=3, learning_rate=0.03,
                        reg_alpha=1.0, reg_lambda=2.0, subsample=0.85, colsample_bytree=0.85,
                        scale_pos_weight=swm, objective="binary:logistic",
                        eval_metric="auc", tree_method="hist", random_state=42, n_jobs=1,
                        base_score=0.5)
                    ms.fit(Xt[ok], meta_y)
                    pmeta_v = ms.predict_proba(Xv)[:, 1]
                    pmeta_e = ms.predict_proba(Xe)[:, 1]
                    # META GATE (AFML): FLATTEN the bar where the secondary predicts the
                    # primary is wrong (p_meta < 0.5); keep the primary signal otherwise.
                    # Only ever REMOVES trades (raising precision) — never adds. The
                    # neutral value that _size flattens to differs by sizing: 0.5 for
                    # long/short (centred), 0.0 for long-only (below any entry thresh).
                    _gate = 0.5 if str(sizing).startswith("ls") else 0.0
                    pv_cal = np.where(pmeta_v >= 0.5, np.asarray(pv_cal), _gate)
                    pe_cal = np.where(pmeta_e >= 0.5, np.asarray(pe_cal), _gate)
                    _meta_booster_json = ms.get_booster().save_raw("json").decode("utf-8")
                    _meta_gate = float(_gate)
                    self.log(f"META {label_cfg}: oos={int(ok.sum())} meta_acc={float(meta_y.mean()):.3f} "
                             f"kept_test={float(np.mean(pmeta_e >= 0.5)):.3f}")
            except Exception as _me:
                try:
                    self.set_runtime_statistic("meta_err", str(_me)[:60])
                except Exception:
                    pass

        # MODEL BUNDLE — frozen artifacts so the OOS backtest can run the model ONLINE
        # (not replay predictions). Bar params (axis/threshold) added by the caller.
        # Guarded; constant_long cells (always_long) carry no model. (online OOS redesign)
        try:
            if ae or (meta and _meta_booster_json is None):
                _bundle = None        # AE (placeholder kept_idx) or meta-without-secondary -> no online bundle
            elif n_pos == 0 or n_neg == 0:
                _bundle = {"constant_long": True, "thresh": float(thresh), "sizing": sizing,
                           "rebal_band": float(CONFIG["rebal_band"]),
                           "train_end": str(TRAIN_END), "val_end": str(VAL_END), "test_end": str(TEST_END)}
            else:
                _cal = locals().get("cal")
                _cx = getattr(_cal, "X_thresholds_", None)
                _cy = getattr(_cal, "y_thresholds_", None)
                _bundle = {"constant_long": False, "thresh": float(thresh), "sizing": sizing,
                           "rebal_band": float(CONFIG["rebal_band"]),
                           "scaler_mean": [float(x) for x in sc.mean_],
                           "scaler_scale": [float(x) for x in sc.scale_],
                           "kept_idx": [int(i) for i in kept_idx],
                           "booster": m.get_booster().save_raw("json").decode("utf-8"),
                           "best_iter": int(getattr(m, "best_iteration", 0) or 0),
                           "n_features": int(len(sc.mean_)),
                           "cal_x": (_cx.tolist() if _cx is not None else []),
                           "cal_y": (_cy.tolist() if _cy is not None else []),
                           "train_end": str(TRAIN_END), "val_end": str(VAL_END), "test_end": str(TEST_END)}
                if meta and _meta_booster_json is not None:
                    # META champion: carry the SECONDARY model + gate so infer_online can
                    # reproduce the gated signal live (same scaler/kept_idx feed both models).
                    _bundle["meta"] = True
                    _bundle["meta_booster"] = _meta_booster_json
                    _bundle["meta_gate"] = float(_meta_gate)
        except Exception as _be:
            _bundle = None
            try:
                self.set_runtime_statistic("hb_bundle_err", str(_be)[:80])
            except Exception:
                pass
        try:
            self.set_runtime_statistic("hb_bundle", "built" if _bundle is not None else "none")
        except Exception:
            pass

        # VAL "middle" metrics over ALL causal val bars (honest OOS preview), at the
        # SAME thresh+sizing infer executes with (no train/infer mismatch).
        synth_cal, n_trades, _, _, _, val_da = _cstats_sized(
            pv_cal[:-1], lc[vi][:-1], lr[vi][1:], thresh, sizing)

        # TEST-period predictions over ALL causal test bars (replayed by infer at
        # the SAME thresh). NO future-label selection -> no look-ahead.
        test_preds = _pred_list(pe_cal[:-1], lc[ei][:-1],
                                np.zeros_like(lc)[ei][:-1], bar_ts[ei][:-1])
        # LEAK SENTINEL (checked every round): preds MUST cover every causal test
        # bar. n_pred << n_test_bars => a labeler is selecting OOS bars by the
        # future label again (the bug fixed 2026-06-01). Echoed as runtime stats.
        try:
            self.set_runtime_statistic("n_test_bars", str(int(ex.sum())))
            self.set_runtime_statistic("n_pred", str(len(test_preds)))
        except Exception:
            pass
        cfg = f"{label_cfg}_corr{nk}_xgbd3_iso"
        return (float(synth_cal), cfg, train_auc, val_auc, int(n_trades),
                test_preds, float(val_da), _bundle)

    def on_end_of_algorithm(self):
        close = np.array(self.cll)
        vol = np.array(self.vll)
        ts_arr = np.array(self.tsl)

        try:
            axis_registry = AXES
        except NameError:
            axis_registry = {"dollar": None}

        # HYPOTHESIS MODE: CONFIG fully specifies the cell -> build ONLY CONFIG['axis']
        # and run ONLY CONFIG['labeler'] as ONE cell (no registry sweep), sizing with
        # CONFIG['sizing'] + CONFIG['thresh']. Active only when BOTH axis and labeler
        # were substituted (back-compat: literal placeholders -> full sweep below).
        cfg_axis = CONFIG.get("axis")
        cfg_label = CONFIG.get("labeler")
        cfg_thresh = CONFIG.get("thresh")
        sizing = CONFIG.get("sizing") or "cdf_overlay"
        hypo_mode = (cfg_axis in axis_registry) and bool(cfg_label)
        if hypo_mode:
            thresh = float(cfg_thresh) if (cfg_thresh is not None and cfg_thresh == cfg_thresh) \
                else _cell_threshold(TICKER)
            axes = [cfg_axis]
            only_label = cfg_label
        else:
            thresh = _cell_threshold(TICKER)
            sizing = "cdf_overlay"
            only_label = None
            # Single substituted axis, or ALL axes if AXIS left literal.
            axes = [AXIS] if AXIS in axis_registry else list(axis_registry.keys())

        cells = []                # manifest entries
        best_da = 1e18            # selection: MIN val Drawdown Area (Wang's val metric)
        best_cal = 0.0
        best_tauc = 0.0
        best_vauc = 0.0
        best_axis = axes[0] if axes else "dollar"
        best_key = None

        for axis in axes:
            try:
                lc, lr, N, bar_ts = build_bars(
                    close, vol, ts_arr, bar_type=axis, target_bars=TARGET_BARS)
            except NameError:
                continue
            if N == 0:
                continue

            # Cross-asset SPY bars on the same axis (reserved; aligned to N).
            try:
                spy_close = np.array(self.spy_cll)
                spy_vol = np.ones_like(spy_close)
                spy_lc, spy_lr, _, _ = build_bars(
                    spy_close, spy_vol, ts_arr, bar_type=axis, target_bars=TARGET_BARS)
                spy_lc = spy_lc[:N]
                spy_lr = spy_lr[:N]
                if len(spy_lc) < N:
                    spy_lc = np.pad(spy_lc, (0, N - len(spy_lc)), 'edge')
                if len(spy_lr) < N:
                    spy_lr = np.pad(spy_lr, (0, N - len(spy_lr)), 'edge')
            except Exception:
                spy_lc = None
                spy_lr = None

            bar_ts_np = np.array([np.datetime64(str(t)) for t in bar_ts])
            tr_m = bar_ts_np < np.datetime64(TRAIN_END)
            va_m = (bar_ts_np >= np.datetime64(TRAIN_END)) & (bar_ts_np < np.datetime64(VAL_END))
            te_m = (bar_ts_np >= np.datetime64(VAL_END)) & (bar_ts_np < np.datetime64(TEST_END))
            try:
                self.set_runtime_statistic("dbg_bars_" + str(axis),
                    str(int(N)) + "/" + str(int(tr_m.sum())) + "/" + str(int(va_m.sum())) + "/" + str(int(te_m.sum())))
            except Exception:
                pass
            if tr_m.sum() < 500 or va_m.sum() < 50 or te_m.sum() < 50:
                continue

            # --- ONLINE-BARS VERIFY (guarded; never breaks training): persist this
            # axis's FROZEN threshold + the batch OOS bars so verify.py can rebuild
            # them ONLINE from the saved threshold and prove byte-identical. Scalar-
            # threshold axes only (entropy/fracdiff need extra fitted params).
            try:
                if axis in BUILDER_CLASSES:
                    _vb = _make_builder(axis, close, vol, ts_arr, TARGET_BARS)
                    _vthr = builder_threshold(_vb) if _vb is not None else None
                    if _vthr is not None:
                        self.object_store.save("autoresearch/" + TICKER + "/oosbars_" + axis + ".json",
                            json.dumps({"bar_type": axis, "bar_thresh": float(_vthr),
                                        "target_bars": int(TARGET_BARS), "n_oos_batch": int(te_m.sum()),
                                        "val_end": str(VAL_END), "test_end": str(TEST_END),
                                        "oos_bar_ts": [str(t)[:19].replace(" ", "T") for t, m in zip(bar_ts, te_m) if m],
                                        "oos_bar_lc": [float(x) for x in lc[te_m]]}))
            except Exception:
                pass

            try:
                feats = build_feats(lc, lr, spy_lc, spy_lr)
            except NameError:
                continue
            except TypeError:
                feats = build_feats(lc, lr)
            fv = ~np.isnan(feats).any(axis=1)
            _hz = CONFIG.get("horizons")     # intraday-holding override (in BARS); None => labeler defaults
            if _hz:
                fwd_ret, fwd_vol = compute_forward_metrics(lc, lr, horizons=_hz)
            else:
                fwd_ret, fwd_vol = compute_forward_metrics(lc, lr)

            # Hypothesis mode -> ONLY CONFIG['labeler']; else sweep the full registry.
            try:
                labeler_registry = LABELERS
            except NameError:
                labeler_registry = {}
            # ⑦ ENSEMBLE: a "+"-joined labeler (e.g. "triple_barrier+bgm") trains EACH
            # sub-labeler's model and AVERAGES their calibrated TEST predictions. All
            # labelers emit preds over the SAME causal test bars (ex = fv & te_m), so the
            # lists align by index. Decorrelated signals -> lower joint drawdown.
            ens_parts = None
            if only_label is not None:
                if "+" in only_label:
                    ens_parts = [p for p in only_label.split("+") if p in labeler_registry]
                    labeler_registry = {p: labeler_registry[p] for p in ens_parts}
                else:
                    labeler_registry = ({only_label: labeler_registry[only_label]}
                                        if only_label in labeler_registry else {})
            _ens_preds, _ens_tauc, _ens_vauc, _ens_bundles = [], [], [], []
            for label_name, label_fn in labeler_registry.items():
                try:
                    if _hz:
                        y, label_cfg, _ = label_fn(
                            lc, lr, tr_m, va_m, te_m, fv, fwd_ret, fwd_vol, horizons=_hz)
                    else:
                        y, label_cfg, _ = label_fn(
                            lc, lr, tr_m, va_m, te_m, fv, fwd_ret, fwd_vol)
                except Exception:
                    y = None
                    label_cfg = f"{label_name}_error"
                if y is None:
                    continue

                try:
                    res = self._run_cell(feats, y, label_cfg or label_name,
                                         tr_m, va_m, te_m, lc, lr, bar_ts, fv, thresh,
                                         sizing, meta=str(label_name).endswith("_meta"),
                                         ae=str(label_name).endswith("_ae"))
                except Exception:
                    res = None                  # a failing leg must not crash the whole train
                if res is None:
                    continue
                synth_cal, cfg, train_auc, val_auc, n_trades, test_preds, val_da, _bundle = res
                if test_preds is None or len(test_preds) == 0:
                    continue
                if ens_parts is not None:           # collect for averaging, don't save per-leg
                    _ens_preds.append(test_preds)
                    _ens_tauc.append(train_auc)
                    _ens_vauc.append(val_auc)
                    _ens_bundles.append(_bundle)     # sub-model bundle for the ONLINE ensemble (live deploy)
                    continue
                aucdiv = abs(train_auc - val_auc)

                key = f"autoresearch/{TICKER}/cell_{axis}_{label_name}_{sizing}_t{int(round(thresh*100))}{_PSUF}.json"
                # Per-cell train/val metrics saved in the payload so the infer
                # backtest can echo them as runtime stats (the driver can't read
                # ObjectStore) and the per-round report has everything per cell.
                self.object_store.save(key, json.dumps({
                    "ticker": TICKER,
                    "axis": axis,
                    "label": label_name,
                    "cfg": cfg,
                    "thresh": thresh,
                    "sizing": sizing,
                    "rebal_band": float(CONFIG["rebal_band"]),
                    "synth_cal": round(synth_cal, 4),
                    "val_da": round(val_da, 4),
                    "train_auc": round(train_auc, 4),
                    "val_auc": round(val_auc, 4),
                    "n_trades": n_trades,
                    "predictions": test_preds,
                }))
                # MODEL BUNDLE (online OOS backtest): frozen model + bar params, saved
                # next to the cell as model_*.json. Scalar-threshold single-labeler axes
                # only (infer v1 scope). Guarded — never breaks the cell save above.
                try:
                    if _bundle is not None and axis in BUILDER_CLASSES:
                        _mb = _make_builder(axis, close, vol, ts_arr, TARGET_BARS)
                        _bthr = builder_threshold(_mb) if _mb is not None else None
                        if _bthr is not None:
                            _bundle["bar_type"] = axis
                            _bundle["bar_thresh"] = float(_bthr)
                            _bundle["target_bars"] = int(TARGET_BARS)
                            self.object_store.save(key.replace("/cell_", "/model_"), json.dumps(_bundle))
                            try:
                                self.set_runtime_statistic("hb_model_saved", "1")
                            except Exception:
                                pass
                except Exception as _se:
                    try:
                        self.set_runtime_statistic("hb_save_err", str(_se)[:80])
                    except Exception:
                        pass
                cells.append({
                    "key": key,
                    "axis": axis,
                    "label": label_name,
                    "synth_cal": round(synth_cal, 4),
                    "val_da": round(val_da, 4),
                    "train_auc": round(train_auc, 4),
                    "val_auc": round(val_auc, 4),
                    "aucdiv": round(aucdiv, 4),
                    "n_trades": n_trades,
                })
                # Pointer selection: MIN val DA among non-overfit cells (AUCdiv<0.05),
                # overfit cells penalized so they only win if nothing else exists.
                score = val_da if aucdiv < 0.05 else val_da + 1e6
                if score < best_da:
                    best_da = score
                    best_cal = synth_cal
                    best_tauc = train_auc
                    best_vauc = val_auc
                    best_axis = axis
                    best_key = key
                self.log(f"CELL {axis}_{label_name}: val_da={round(val_da,4)} "
                         f"synth_cal={round(synth_cal,4)} train_auc={round(train_auc,4)} "
                         f"val_auc={round(val_auc,4)} aucdiv={round(aucdiv,4)} n_trades={n_trades}")

            # ⑦ ENSEMBLE: average the sub-labelers' calibrated TEST predictions (index-aligned,
            # same ex bars). Save ONE cell keyed by the "+"-joined name (matches the driver's
            # cell string + infer CELL), so infer replays the averaged signal.
            if ens_parts is not None and len(_ens_preds) >= 2:
                ml = min(len(p) for p in _ens_preds)
                ens_list = []
                for i in range(ml):
                    avg_p = sum(float(pp[i]["pred"]) for pp in _ens_preds) / len(_ens_preds)
                    ens_list.append({"time": _ens_preds[0][i]["time"],
                                     "pred": float(avg_p), "above_ma": True})
                e_tauc = sum(_ens_tauc) / len(_ens_tauc)
                e_vauc = sum(_ens_vauc) / len(_ens_vauc)
                ename = "+".join(ens_parts)
                ekey_name = ename.replace("+", "_x_")   # ObjectStore key: no '+' (path-safe), matches driver
                ekey = f"autoresearch/{TICKER}/cell_{axis}_{ekey_name}_{sizing}_t{int(round(thresh*100))}{_PSUF}.json"
                self.object_store.save(ekey, json.dumps({
                    "ticker": TICKER, "axis": axis, "label": ename, "cfg": f"ensemble_{ename}",
                    "thresh": thresh, "sizing": sizing, "rebal_band": float(CONFIG["rebal_band"]), "synth_cal": 0.0, "val_da": 0.0,
                    "train_auc": round(e_tauc, 4), "val_auc": round(e_vauc, 4),
                    "n_trades": len(ens_list), "predictions": ens_list,
                }))
                cells.append({"key": ekey, "axis": axis, "label": ename, "synth_cal": 0.0,
                              "val_da": 0.0, "train_auc": round(e_tauc, 4), "val_auc": round(e_vauc, 4),
                              "aucdiv": round(abs(e_tauc - e_vauc), 4), "n_trades": len(ens_list)})
                # ENSEMBLE ONLINE BUNDLE (2026-06-03): save the sub-model bundles + bar params so the live/
                # online path can reproduce the AVERAGED calibrated prediction online (load each member, run it,
                # average). Without this, ensemble champions (the real edges: GLD ker+regime_gmm, UUP bgm+ker) had
                # NO online bundle and could not be live-deployed. Guarded; never breaks the cell save above.
                try:
                    _mem = [b for b in _ens_bundles if (b is not None and "booster" in b and not b.get("constant_long"))]
                    if len(_mem) >= 2 and axis in BUILDER_CLASSES:
                        _emb = _make_builder(axis, close, vol, ts_arr, TARGET_BARS)
                        _ebthr = builder_threshold(_emb) if _emb is not None else None
                        if _ebthr is not None:
                            _eb = {"ensemble": True, "constant_long": False, "members": _mem,
                                   "thresh": float(thresh), "sizing": sizing, "rebal_band": float(CONFIG["rebal_band"]),
                                   "bar_type": axis, "bar_thresh": float(_ebthr), "target_bars": int(TARGET_BARS),
                                   "n_features": int(_mem[0].get("n_features", 0) or 0),
                                   "val_end": str(VAL_END), "test_end": str(TEST_END)}
                            self.object_store.save(ekey.replace("/cell_", "/model_"), json.dumps(_eb))
                            try:
                                self.set_runtime_statistic("hb_ens_bundle", str(len(_mem)))
                            except Exception:
                                pass
                except Exception as _ee:
                    try:
                        self.set_runtime_statistic("hb_ens_bundle_err", str(_ee)[:80])
                    except Exception:
                        pass
                best_key = ekey
                best_cal = 0.0
                best_tauc = e_tauc
                best_vauc = e_vauc
                best_axis = axis
                self.log(f"ENSEMBLE {axis}_{ename}: legs={len(_ens_preds)} n_pred={len(ens_list)} "
                         f"train_auc={round(e_tauc,4)} val_auc={round(e_vauc,4)}")

        # Manifest of all cells (for the driver / infer cell selection).
        self.object_store.save(f"autoresearch/{TICKER}/manifest.json", json.dumps({
            "ticker": TICKER,
            "thresh": thresh,
            "sizing": sizing,
            "n_cells": len(cells),
            "cells": cells,
        }))
        # Latest pointer = the cell selected by MIN val DA (Wang's val metric).
        if best_key is not None:
            self.object_store.save(f"autoresearch/{TICKER}/latest_key.json",
                                   json.dumps({"key": best_key}))

        # Stats consumed by validate_script()/orchestrator (best_cal, train_auc,
        # val_auc MUST be set). best_* describe the val-DA-selected cell.
        self.set_runtime_statistic("best_cal", str(round(float(best_cal), 4)))
        self.set_runtime_statistic("best_da", str(round(float(best_da if best_da < 1e17 else 0.0), 4)))
        self.set_runtime_statistic("train_auc", str(round(float(best_tauc), 4)))
        self.set_runtime_statistic("val_auc", str(round(float(best_vauc), 4)))
        self.set_runtime_statistic("n_cells", str(len(cells)))
        self.set_runtime_statistic("bar_type", str(best_axis))
        try:
            import xgboost as _xgbv, sklearn as _skv
            self.set_runtime_statistic("xgb_version", str(_xgbv.__version__))
            self.set_runtime_statistic("skl_version", str(_skv.__version__))
        except Exception:
            pass
        self.log(f"SWEEP done: n_cells={len(cells)} best_da={round(float(best_da),4)} "
                 f"best_cal={round(float(best_cal),4)} best_axis={best_axis}")
