from AlgorithmImports import *
import json
import math
import numpy as np
from datetime import datetime

# Render-time sizing — the SAME _size() rule the footer used for VAL, replayed
# here for OOS. mode + thresh come from the saved cell payload (no mismatch).
#   ramp        = min(1,(p-thresh)*200) if p>thresh else 0          (legacy)
#   binary      = 1.0 if p>thresh else 0.0                          (label-responsive)
#   cdf_plain   = clip(2*Phi((p-thresh)/sqrt(p(1-p)))-1,0,1) if p>thresh else 0
#   cdf_overlay = cdf_plain * clip(std_slow/std_fast, 0.6, 1.0)     (vol-targeted)
_VOL_FAST = 10
_VOL_SLOW = 60


def _size(p, thresh, sizing, rbuf):
    if sizing == "longshort":
        return 1.0 if p > thresh else (-1.0 if p < 1.0 - thresh else 0.0)
    if sizing in ("ls_cdf", "ls_overlay"):
        pp = min(max(p, 1e-6), 1.0 - 1e-6)
        zc = (pp - 0.5) / math.sqrt(pp * (1.0 - pp))
        w = float(min(1.0, max(-1.0, 2.0 * 0.5 * (1.0 + math.erf(zc / math.sqrt(2.0))) - 1.0)))
        if sizing == "ls_overlay":              # vol-target the long/short magnitude, keep sign (causal)
            m = len(rbuf)
            if m >= _VOL_FAST + 2:
                fast = float(np.std(rbuf[-_VOL_FAST:]))
                slow = float(np.std(rbuf[-min(m, _VOL_SLOW):]))
                if fast > 1e-9:
                    w *= float(min(1.0, max(0.45, slow / fast)))
        return w
    if sizing == "binary":
        return 1.0 if p > thresh else 0.0
    if sizing == "ramp":
        return float(min(1.0, (p - thresh) * 200.0)) if p > thresh else 0.0
    if p <= thresh:
        return 0.0
    pp = min(max(p, 1e-6), 1 - 1e-6)
    z = (pp - thresh) / math.sqrt(pp * (1.0 - pp))
    b = 2.0 * 0.5 * (1.0 + math.erf(z / math.sqrt(2.0))) - 1.0  # 2*Phi(z)-1
    b = float(min(1.0, max(0.0, b)))
    if sizing == "cdf_overlay":
        m = len(rbuf)
        if m >= _VOL_FAST + 2:
            fast = float(np.std(rbuf[-_VOL_FAST:]))
            slow = float(np.std(rbuf[-min(m, _VOL_SLOW):]))
            if fast > 1e-9:
                b *= float(min(1.0, max(0.6, slow / fast)))
    return b

TICKER = "__TICKER__"
# Cell selector "{axis}_{label}" substituted by the driver. If left literal
# "__CELL__", fall back to the val-DA-selected best cell via latest_key.json.
CELL = "__CELL__"


class AutoresearchInfer(QCAlgorithm):
    def initialize(self):
        self.set_start_date(2023, 8, 1)   # OOS window
        self.set_end_date(2026, 6, 1)
        self.set_cash(100000)
        self.sym = self.add_equity(TICKER, Resolution.MINUTE).symbol
        self.preds = []
        self.idx = 0
        self.thresh = 0.45
        self.sizing = "cdf_overlay"
        self.meta = {}
        self._eq = []          # daily equity, for Drawdown Area
        self._last_day = None
        self._rbuf = []        # trailing bar log-returns (causal, for inverse-vol)
        self._last_close = None
        self._cur_w = 0.0      # current target weight (rebalance dead-band)
        try:
            if CELL == ("__" "CELL__"):   # split literal so render's .replace can't clobber this guard
                ptr = json.loads(self.object_store.read(f"autoresearch/{TICKER}/latest_key.json"))
                key = ptr["key"]
            else:
                key = f"autoresearch/{TICKER}/cell_{CELL}.json"
            data = json.loads(self.object_store.read(key))
            self.preds = data.get("predictions", [])
            if data.get("thresh") is not None:
                self.thresh = float(data["thresh"])
            if data.get("sizing"):
                self.sizing = str(data["sizing"])
            self.meta = {k: data.get(k) for k in
                         ("synth_cal", "val_da", "train_auc", "val_auc", "cfg")}
        except Exception:
            self.preds = []

    def on_data(self, slice):
        # Sample equity once per day (for DA), regardless of prediction state.
        now = self.time.date()
        if now != self._last_day:
            self._last_day = now
            self._eq.append(float(self.portfolio.total_portfolio_value))

        if self.idx >= len(self.preds):
            return
        if self.sym not in slice.bars:
            return
        b = slice.bars[self.sym]
        p = self.preds[self.idx]
        try:
            pred_time = datetime.strptime(p["time"][:19], "%Y-%m-%dT%H:%M:%S")
        except Exception:
            pred_time = b.end_time
        if b.end_time >= pred_time:
            self.idx += 1
            # _size() uses returns KNOWN at this bar (causal): decide size from
            # _rbuf, THEN append this bar's realized return. SAME rule as VAL.
            w = _size(float(p["pred"]), self.thresh, self.sizing, self._rbuf)
            # Rebalance dead-band 0.01; w may be NEGATIVE (short) now.
            if abs(w) < 0.01:                       # flat band
                if self._cur_w != 0.0:
                    self.liquidate(self.sym)
                    self._cur_w = 0.0
            elif abs(w - self._cur_w) > 0.01:       # long (w>0) OR short (w<0)
                self.set_holdings(self.sym, w)
                self._cur_w = w
            c = float(b.close)
            if self._last_close is not None and self._last_close > 0:
                self._rbuf.append(math.log(c / self._last_close))
            self._last_close = c

    def on_end_of_algorithm(self):
        # Real OOS Drawdown Area: DA = Σ_t (1 - E_t / peak_t) on daily equity.
        da, peak = 0.0, None
        for v in self._eq:
            peak = v if (peak is None or v > peak) else peak
            if peak and peak > 0:
                da += 1.0 - v / peak
        self.set_runtime_statistic("da_oos", str(round(da, 4)))
        # OOS daily Sharpe + higher moments + N — the inputs for PSR / Deflated-Sharpe
        # trials-adjustment (selection-bias control). Computed from daily equity.
        eq = np.array(self._eq, dtype=float)
        if len(eq) > 4:
            rets = np.diff(eq) / np.where(eq[:-1] == 0, np.nan, eq[:-1])
            rets = rets[np.isfinite(rets)]
            sd = float(np.std(rets, ddof=1)) if len(rets) > 3 else 0.0
            if len(rets) > 3 and sd > 1e-12:
                mu = float(np.mean(rets))
                z = (rets - mu) / sd
                self.set_runtime_statistic("sharpe_oos", str(round(mu / sd * (252.0 ** 0.5), 4)))
                self.set_runtime_statistic("skew_oos", str(round(float(np.mean(z ** 3)), 4)))
                self.set_runtime_statistic("kurt_oos", str(round(float(np.mean(z ** 4)), 4)))
                self.set_runtime_statistic("n_days", str(int(len(rets))))
        # Echo the per-cell train/val metrics so the round runner has them.
        for k in ("synth_cal", "val_da", "train_auc", "val_auc"):
            if self.meta.get(k) is not None:
                self.set_runtime_statistic(k, str(self.meta[k]))
