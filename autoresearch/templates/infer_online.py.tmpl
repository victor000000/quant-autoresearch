TICKER = "__TICKER__"
CELL = "__CELL__"
_WARMUP = 820           # >= max feature window (800) + margin
_TRAIL = 840            # bars of trailing history fed to build_feats (>= _WARMUP)
_XSTRIDE = 20           # cross-check every Nth OOS bar (build_feats is the bottleneck)


class OnlineInferXCheck(QCAlgorithm):
    """Frozen-model ONLINE OOS replica + cross-check. Replays the 2009->2026 feed,
    builds bars ONLINE from the saved frozen threshold, computes features on a trailing
    window (identical last-row to the full-history build), runs the FROZEN booster +
    isotonic online, and asserts p_live == p_saved (the train's saved predictions) to
    prove the online path reproduces the batch one. NOTHING is refit here."""

    def initialize(self):
        self.set_start_date(2009, 8, 1)
        self.set_end_date(2026, 6, 1)
        self.set_cash(100000)
        self.sym = self.add_equity(TICKER, Resolution.MINUTE).symbol
        self.cll = []
        self.vll = []
        self.tsl = []
        self.blc = []        # per-bar log-close (online)
        self.diffs = []      # |p_live - p_saved| over matched OOS bars
        self.n_live = 0
        self.ok = True
        try:
            mb = json.loads(self.object_store.read("autoresearch/" + TICKER + "/model_" + CELL + ".json"))
            cell = json.loads(self.object_store.read("autoresearch/" + TICKER + "/cell_" + CELL + ".json"))
        except Exception as e:
            self.set_runtime_statistic("xerr", "load:" + str(e)[:60])
            self.ok = False
            return
        self.mb = mb
        self.constant_long = bool(mb.get("constant_long"))
        self.vend = np.datetime64(mb.get("val_end"))
        self.tend = np.datetime64(mb.get("test_end"))
        bt = mb.get("bar_type")
        cls = BUILDER_CLASSES.get(bt) if not self.constant_long else None
        if not self.constant_long and cls is None:
            self.set_runtime_statistic("xerr", "no_builder:" + str(bt))
            self.ok = False
            return
        self.builder = cls(float(mb["bar_thresh"])) if cls is not None else None
        if not self.constant_long:
            self.nfeat = int(mb.get("n_features", 0) or 0)
            # ENSEMBLE (the deployed real edges GLD trend_leg+regime_gmm / UUP bgm+ker) OR single-labeler.
            # Load EACH member; the online prediction AVERAGES the members' calibrated+gated probs (mirrors the
            # footer's ensemble + live_trade.py.tmpl), so p_live reproduces the saved ENSEMBLE prediction. Without
            # this, ensemble bundles ({"ensemble":True,"members":[...]}, no top-level booster) raised KeyError and
            # the deployed ensemble champions' online-equivalence was unprovable (2026-06-03 audit finding #1).
            raw_members = mb["members"] if mb.get("ensemble") else [mb]
            self.members = [self._load_member(b) for b in raw_members]
            self.set_runtime_statistic("n_members", str(len(self.members)))
        # saved predictions keyed by bar timestamp (for the cross-check)
        self.saved = {}
        for p in cell.get("predictions", []):
            self.saved[str(p.get("time"))[:19].replace(" ", "T")] = float(p.get("pred"))

    def _load_member(self, b):
        booster = xgb.Booster()
        booster.load_model(bytearray(b["booster"], "utf-8"))
        m = {"mean": np.array(b["scaler_mean"], dtype=float),
             "scale": np.array(b["scaler_scale"], dtype=float),
             "kept": np.array(b["kept_idx"], dtype=int),
             "cal_x": np.array(b.get("cal_x", []), dtype=float),
             "cal_y": np.array(b.get("cal_y", []), dtype=float),
             "best_iter": int(b.get("best_iter", 0) or 0),
             "booster": booster, "is_meta": bool(b.get("meta")), "meta_booster": None, "meta_gate": 0.0}
        if m["is_meta"]:
            mbst = xgb.Booster()
            mbst.load_model(bytearray(b["meta_booster"], "utf-8"))
            m["meta_booster"] = mbst
            m["meta_gate"] = float(b.get("meta_gate", 0.0))
        return m

    def _predict_member(self, m, row):
        x = ((row - m["mean"]) / m["scale"])[m["kept"]]
        dm = xgb.DMatrix(x.reshape(1, -1))
        if m["best_iter"] > 0:
            praw = float(m["booster"].predict(dm, iteration_range=(0, m["best_iter"] + 1))[0])
        else:
            praw = float(m["booster"].predict(dm)[0])
        p = float(np.interp(praw, m["cal_x"], m["cal_y"])) if len(m["cal_x"]) >= 2 else praw
        if m["is_meta"]:                              # meta GATE: flatten where the secondary distrusts the primary
            pmeta = float(m["meta_booster"].predict(dm)[0])
            if pmeta < 0.5:
                p = m["meta_gate"]
        return p

    def on_data(self, slice):
        if not self.ok or self.constant_long or self.sym not in slice.bars:
            return
        b = slice.bars[self.sym]
        self.cll.append(float(b.close))
        self.vll.append(float(b.volume))
        self.tsl.append(b.end_time)
        bar = self.builder.update(b.end_time, float(b.close), float(b.volume))
        if bar is None:
            return
        self.blc.append(float(bar["log_close"]))
        norm = str(b.end_time)[:19].replace(" ", "T")
        t64 = np.datetime64(norm)
        if not (self.vend <= t64 < self.tend):     # OOS-window emission only
            return
        if len(self.blc) < _WARMUP:
            return
        self._oc = getattr(self, "_oc", 0) + 1      # cross-check a subsample (speed)
        if self._oc % _XSTRIDE != 0:
            return
        lc = np.array(self.blc[-_TRAIL:], dtype=float)
        lr = np.zeros_like(lc)
        lr[1:] = lc[1:] - lc[:-1]
        abs_start = len(self.blc) - len(lc)        # absolute index of lc[0] -> anchored entropy grid
        try:
            feats = build_feats(lc, lr, abs_start=abs_start)
        except Exception:
            return
        row = feats[-1]
        if np.isnan(row).any():
            return
        if self.nfeat and len(row) != self.nfeat:
            self.set_runtime_statistic("featlen_mismatch", str(len(row)) + "vs" + str(self.nfeat))
        # AVERAGE the members' calibrated+gated probs (single-labeler => 1 member; mirrors footer ensemble + live).
        plive = float(np.mean([self._predict_member(m, row) for m in self.members]))
        psaved = self.saved.get(norm)
        if psaved is not None:
            d = abs(plive - psaved)
            self.diffs.append(d)
            self.n_live += 1
            if len(self.diffs) <= 1:                 # sample the first matched pair
                self.set_runtime_statistic("sample_live", str(round(plive, 5)))
                self.set_runtime_statistic("sample_saved", str(round(psaved, 5)))

    def on_end_of_algorithm(self):
        if not self.ok:
            return
        if self.constant_long:
            self.set_runtime_statistic("constant_long", "1")
            self.quit("constant_long cell — no model to cross-check")
            return
        n = len(self.diffs)
        maxd = max(self.diffs) if self.diffs else -1.0
        match = 1 if (n > 0 and maxd <= 1e-6) else 0
        n_big = sum(1 for d in self.diffs if d > 0.01)
        meand = (sum(self.diffs) / n) if n else -1.0
        self.set_runtime_statistic("preds_match", str(match))
        self.set_runtime_statistic("n_matched", str(n))
        self.set_runtime_statistic("n_big_gt01", str(n_big))
        self.set_runtime_statistic("mean_diff", str(round(meand, 6)))
        self.set_runtime_statistic("n_saved", str(len(self.saved)))
        self.set_runtime_statistic("max_pred_diff", str(round(maxd, 9)))
        self.quit("online-infer cross-check done")
